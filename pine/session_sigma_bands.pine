//@version=6
// =============================================================================
// Session Segments + σ-Bands  (all-in-one)
// -----------------------------------------------------------------------------
// Two tools in one, matching the web app's Asset-Stats engine:
//
// 1. SEGMENT MAP — shade each trading day into its five mutually-exclusive
//    reference segments (solo sessions + the two overlaps):
//        Tokyo (solo) · Tokyo∩London · London (solo) · London∩NY · New York (solo)
//
// 2. σ-BANDS PER REFERENCE — for EACH of those five segments, its log return
//    r = ln(close/open) is collected over a rolling history into mean (mu) and
//    std (sigma). When that segment opens, its ±0.5/1/1.5/2σ bands are anchored
//    at its open (using the PRIOR distribution — causal, non-repainting) and
//    drawn forward to the end of the trading day. Each segment's bands have
//    their own on/off toggle.
//
// The bands are drawn as LINE objects (not plots), so all five segments × eight
// levels fit without hitting TradingView's 64-plot limit. Line history is
// bounded by max_lines_count, so only recent days keep their bands on screen.
//
// Sessions are defined in each centre's own timezone, so TradingView applies
// DST automatically. Use an intraday timeframe (5m .. 4h).
// =============================================================================
indicator("Session Segments + σ-Bands", overlay = true,
     max_labels_count = 500, max_lines_count = 500)

if not timeframe.isintraday
    runtime.error("Use an intraday timeframe (< 1D) — sessions need sub-daily bars.")

// ----------------------------- inputs ----------------------------------------
grpS = "Sessions (local wall-clock, DST via timezone)"
tkSess = input.session("0900-1800", "Tokyo hours",     group = grpS)
tkTz   = input.string ("Asia/Tokyo", "Tokyo timezone", group = grpS)
lnSess = input.session("0800-1700", "London hours",    group = grpS)
lnTz   = input.string ("Europe/London", "London timezone", group = grpS)
nySess = input.session("0800-1700", "New York hours",  group = grpS)
nyTz   = input.string ("America/New_York", "New York timezone", group = grpS)

grpM = "Distribution"
lookback   = input.int(250, "Rolling window (segments, per type)", minval = 20, group = grpM)
minSamples = input.int(30,  "Min segments before drawing bands",  minval = 2,  group = grpM)
showHalf   = input.bool(true, "Show ±0.5σ and ±1.5σ bands",        group = grpM)
showMeanMode = input.bool(true, "Draw mean (bold) & mode (dashed)", group = grpM)
labelMM      = input.bool(true, "Label μ and Mo",                   group = grpM)

grpZ = "Segment shading"
shadeSeg = input.bool(true, "Shade segments (background)", group = grpZ)
sTk   = input.bool(true, "Tokyo (solo)",      group = grpZ)
sTkLn = input.bool(true, "Tokyo ∩ London",    group = grpZ)
sLn   = input.bool(true, "London (solo)",     group = grpZ)
sLnNy = input.bool(true, "London ∩ New York", group = grpZ)
sNy   = input.bool(true, "New York (solo)",   group = grpZ)

grpB = "σ-Bands per reference — activate each"
bTk   = input.bool(false, "Tokyo (solo) bands",      group = grpB)
bTkLn = input.bool(true,  "Tokyo ∩ London bands",    group = grpB)
bLn   = input.bool(false, "London (solo) bands",     group = grpB)
bLnNy = input.bool(true,  "London ∩ New York bands", group = grpB)
bNy   = input.bool(false, "New York (solo) bands",   group = grpB)

grpD = "Display"
showLegend = input.bool(true,  "Legend",           group = grpD)
showLabels = input.bool(false, "Label segments",   group = grpD)
cTk   = input.color(color.red,    "Tokyo colour",        group = grpD)
cTkLn = input.color(color.orange, "Tokyo∩London colour", group = grpD)
cLn   = input.color(color.blue,   "London colour",       group = grpD)
cLnNy = input.color(color.teal,   "London∩NY colour",    group = grpD)
cNy   = input.color(color.green,  "New York colour",     group = grpD)

// ----------------------------- session zones ---------------------------------
tkIn = not na(time(timeframe.period, tkSess, tkTz))
lnIn = not na(time(timeframe.period, lnSess, lnTz))
nyIn = not na(time(timeframe.period, nySess, nyTz))

zTkLn = tkIn and lnIn                         // Tokyo ∩ London
zLnNy = lnIn and nyIn                         // London ∩ New York
zTk   = tkIn and not lnIn                     // Tokyo before London
zLn   = lnIn and not tkIn and not nyIn        // London, after Tokyo & before NY
zNy   = nyIn and not lnIn                     // New York after London

dayEnd = nyIn[1] and not nyIn                 // end of the trading day (NY close)

// Mode of a return sample, estimated as the centre of the densest histogram
// bin (there is no built-in mode). Returns na for tiny samples.
f_mode(array<float> a) =>
    n = array.size(a)
    float m = na
    if n >= 5
        float lo = array.min(a)
        float hi = array.max(a)
        float rng = hi - lo
        if rng <= 0
            m := lo
        else
            int bins = math.min(24, math.max(5, int(math.sqrt(n))))
            counts = array.new_int(bins, 0)
            for i = 0 to n - 1
                float v = array.get(a, i)
                int bi = math.min(int((v - lo) / rng * bins), bins - 1)
                array.set(counts, bi, array.get(counts, bi) + 1)
            int best = 0
            int bestc = -1
            for b = 0 to bins - 1
                int c = array.get(counts, b)
                if c > bestc
                    bestc := c
                    best := b
            m := lo + (best + 0.5) / bins * rng
    m

// ----------------------------- reference segments ----------------------------
type Seg
    array<float> rets
    float mean = na
    float sd   = na
    float mode = na               // densest-bin estimate of the return mode
    float runOpen = na            // running open of the in-progress instance
    bool  on = false              // bands active (segment open → day end)
    bool  armed = false           // fired on the bar the segment opens
    float mLevel  = na            // mean price level (anchored at seg open)
    float moLevel = na            // mode price level
    line  lMean = na
    line  lMode = na
    float u05 = na
    float u1  = na
    float u15 = na
    float u2  = na
    float d05 = na
    float d1  = na
    float d15 = na
    float d2  = na
    line lu05 = na
    line lu1  = na
    line lu15 = na
    line lu2  = na
    line ld05 = na
    line ld1  = na
    line ld15 = na
    line ld2  = na

// Arm bands at segment open from the PRIOR distribution; collect the return at
// segment close; clear the band set at the end of the trading day.
method step(Seg s, bool inSeg, bool endOfDay) =>
    s.armed := false
    if inSeg and not inSeg[1]
        s.runOpen := open
        if not na(s.mean) and not na(s.sd) and array.size(s.rets) >= minSamples
            float o = open
            s.u05 := o * math.exp(s.mean + 0.5 * s.sd)
            s.u1  := o * math.exp(s.mean + 1.0 * s.sd)
            s.u15 := o * math.exp(s.mean + 1.5 * s.sd)
            s.u2  := o * math.exp(s.mean + 2.0 * s.sd)
            s.d05 := o * math.exp(s.mean - 0.5 * s.sd)
            s.d1  := o * math.exp(s.mean - 1.0 * s.sd)
            s.d15 := o * math.exp(s.mean - 1.5 * s.sd)
            s.d2  := o * math.exp(s.mean - 2.0 * s.sd)
            s.mLevel  := o * math.exp(s.mean)
            s.moLevel := na(s.mode) ? na : o * math.exp(s.mode)
            s.on    := true
            s.armed := true
    if inSeg[1] and not inSeg
        r = math.log(close[1] / s.runOpen)
        if not na(r)
            array.push(s.rets, r)
            if array.size(s.rets) > lookback
                array.shift(s.rets)
            if array.size(s.rets) >= 2
                s.mean := array.avg(s.rets)
                s.sd   := array.stdev(s.rets, false)   // sample std (ddof=1)
                s.mode := f_mode(s.rets)
    if endOfDay
        s.on := false

// Draw / extend this segment's band lines (line objects, not plots).
method draw(Seg s, bool en, color col) =>
    if s.armed
        // reset references each new segment instance so we never extend an
        // earlier day's line; recreate only the enabled levels
        s.lu05 := na
        s.lu1  := na
        s.lu15 := na
        s.lu2  := na
        s.ld05 := na
        s.ld1  := na
        s.ld15 := na
        s.ld2  := na
        s.lMean := na
        s.lMode := na
        if en
            s.lu1 := line.new(bar_index, s.u1, bar_index, s.u1, xloc = xloc.bar_index, color = color.new(col, 46))
            s.lu2 := line.new(bar_index, s.u2, bar_index, s.u2, xloc = xloc.bar_index, color = color.new(col, 16))
            s.ld1 := line.new(bar_index, s.d1, bar_index, s.d1, xloc = xloc.bar_index, color = color.new(col, 46))
            s.ld2 := line.new(bar_index, s.d2, bar_index, s.d2, xloc = xloc.bar_index, color = color.new(col, 16))
            if showHalf
                s.lu05 := line.new(bar_index, s.u05, bar_index, s.u05, xloc = xloc.bar_index, color = color.new(col, 66), style = line.style_dotted)
                s.lu15 := line.new(bar_index, s.u15, bar_index, s.u15, xloc = xloc.bar_index, color = color.new(col, 32), style = line.style_dotted)
                s.ld05 := line.new(bar_index, s.d05, bar_index, s.d05, xloc = xloc.bar_index, color = color.new(col, 66), style = line.style_dotted)
                s.ld15 := line.new(bar_index, s.d15, bar_index, s.d15, xloc = xloc.bar_index, color = color.new(col, 32), style = line.style_dotted)
            if showMeanMode
                // mean: bold solid; mode: dashed — distinct from the σ bands
                s.lMean := line.new(bar_index, s.mLevel, bar_index, s.mLevel, xloc = xloc.bar_index, color = color.new(col, 5), width = 2)
                if labelMM
                    label.new(bar_index, s.mLevel, "μ", xloc = xloc.bar_index, style = label.style_none, textcolor = color.new(col, 0), size = size.tiny)
                if not na(s.moLevel)
                    s.lMode := line.new(bar_index, s.moLevel, bar_index, s.moLevel, xloc = xloc.bar_index, color = color.new(col, 20), width = 1, style = line.style_dashed)
                    if labelMM
                        label.new(bar_index, s.moLevel, "Mo", xloc = xloc.bar_index, style = label.style_none, textcolor = color.new(col, 0), size = size.tiny)
    if en and s.on
        if not na(s.lu1)
            line.set_x2(s.lu1, bar_index)
        if not na(s.lu2)
            line.set_x2(s.lu2, bar_index)
        if not na(s.ld1)
            line.set_x2(s.ld1, bar_index)
        if not na(s.ld2)
            line.set_x2(s.ld2, bar_index)
        if not na(s.lu05)
            line.set_x2(s.lu05, bar_index)
        if not na(s.lu15)
            line.set_x2(s.lu15, bar_index)
        if not na(s.ld05)
            line.set_x2(s.ld05, bar_index)
        if not na(s.ld15)
            line.set_x2(s.ld15, bar_index)
        if not na(s.lMean)
            line.set_x2(s.lMean, bar_index)
        if not na(s.lMode)
            line.set_x2(s.lMode, bar_index)

var segTk   = Seg.new(rets = array.new<float>())
var segTkLn = Seg.new(rets = array.new<float>())
var segLn   = Seg.new(rets = array.new<float>())
var segLnNy = Seg.new(rets = array.new<float>())
var segNy   = Seg.new(rets = array.new<float>())

segTk.step(zTk, dayEnd)
segTkLn.step(zTkLn, dayEnd)
segLn.step(zLn, dayEnd)
segLnNy.step(zLnNy, dayEnd)
segNy.step(zNy, dayEnd)

segTk.draw(bTk, cTk)
segTkLn.draw(bTkLn, cTkLn)
segLn.draw(bLn, cLn)
segLnNy.draw(bLnNy, cLnNy)
segNy.draw(bNy, cNy)

// ----------------------------- segment shading -------------------------------
bg = (zTkLn and sTkLn) ? color.new(cTkLn, 80) :
     (zLnNy and sLnNy) ? color.new(cLnNy, 80) :
     (zTk   and sTk)   ? color.new(cTk,   90) :
     (zLn   and sLn)   ? color.new(cLn,   90) :
     (zNy   and sNy)   ? color.new(cNy,   90) : na
bgcolor(shadeSeg ? bg : na, title = "Segment shading")

// ----------------------------- labels ----------------------------------------
zoneName = zTkLn ? "Tokyo ∩ London" : zLnNy ? "London ∩ NY" :
           zTk ? "Tokyo" : zLn ? "London" : zNy ? "New York" : ""
zoneCol  = zTkLn ? cTkLn : zLnNy ? cLnNy : zTk ? cTk : zLn ? cLn : zNy ? cNy : color.gray
if showLabels and zoneName != "" and zoneName != zoneName[1]
    label.new(bar_index, high, zoneName, style = label.style_label_down,
         color = color.new(zoneCol, 20), textcolor = color.white, size = size.tiny)

// ----------------------------- legend ----------------------------------------
var table lg = table.new(position.top_right, 3, 6, border_width = 1)
f_row(int r, string name, color col, bool bandOn) =>
    table.cell(lg, 0, r, "  ", bgcolor = color.new(col, 30))
    table.cell(lg, 1, r, name, text_color = color.white, text_size = size.tiny)
    table.cell(lg, 2, r, bandOn ? "on" : "—",
         text_color = bandOn ? color.white : color.gray, text_size = size.tiny)

if showLegend and barstate.islast
    table.cell(lg, 0, 0, "seg", text_color = color.gray, text_size = size.tiny)
    table.cell(lg, 1, 0, "zone", text_color = color.gray, text_size = size.tiny)
    table.cell(lg, 2, 0, "bands", text_color = color.gray, text_size = size.tiny)
    f_row(1, "Tokyo (solo)",      cTk,   bTk)
    f_row(2, "Tokyo ∩ London",    cTkLn, bTkLn)
    f_row(3, "London (solo)",     cLn,   bLn)
    f_row(4, "London ∩ New York", cLnNy, bLnNy)
    f_row(5, "New York (solo)",   cNy,   bNy)
