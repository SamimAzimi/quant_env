//@version=6
// =============================================================================
// Session σ-Bands (live behaviour overlay)
// -----------------------------------------------------------------------------
// Draw each session's ±1σ / ±2σ bands on the chart and WATCH how price behaves
// against them — the same way on history and on the live bar.
//
// For an ordered pair (reference -> trigger):
//   * the REFERENCE session's log return  r = ln(close/open)  is collected over
//     a rolling history into  mean (mu)  and  std (sigma);
//   * bands are anchored at that reference session's OPEN price:
//         +1σ = open*exp(mu+sigma)   +2σ = open*exp(mu+2sigma)   (and -1σ,-2σ);
//   * those bands are then SHOWN LIVE across the following TRIGGER session, so
//     you see, bar by bar, whether price holds inside, pokes past ±1σ, or
//     extends to ±2σ.
//
// The bands are CAUSAL and NON-REPAINTING: each session's mu/sigma uses only
// prior completed sessions, and a band level is fixed the moment the reference
// session closes — so what you see historically is exactly what you'd have had
// live. Bars are tinted while price closes beyond a band, and a triangle marks
// the first close beyond ±1σ within a trigger session (the behavioural event).
//
// Pairs:  Tokyo -> London,  London -> New York,  New York -> London (overnight).
// Use an INTRADAY timeframe (5m .. 4h). Sessions are in each centre's own
// timezone, so TradingView applies DST automatically.
// =============================================================================
indicator("Session σ-Bands (live)", overlay = true)

if not timeframe.isintraday
    runtime.error("Use an intraday timeframe (< 1D) — sessions need sub-daily bars.")

// ----------------------------- inputs ----------------------------------------
grpS = "Sessions (local wall-clock, DST via timezone)"
tkSess = input.session("0900-1800", "Tokyo hours",     group = grpS)
tkTz   = input.string ("Asia/Tokyo", "Tokyo timezone", group = grpS)
lnSess = input.session("0800-1700", "London hours",    group = grpS)
lnTz   = input.string ("Europe/London", "London timezone", group = grpS)
nySess = input.session("0800-1700", "New York hours",  group = grpS)
nyTz   = input.string ("America/New_York", "New York timezone", group = grpS)

grpM = "Distribution"
lookback   = input.int(250, "Rolling window (sessions, per type)", minval = 20, group = grpM)
minSamples = input.int(30,  "Min sessions before drawing bands",   minval = 2,  group = grpM)

grpP = "Which reference frame to overlay"
showTL = input.bool(true,  "Tokyo → London",             group = grpP)
showLN = input.bool(true,  "London → New York",          group = grpP)
showNL = input.bool(false, "New York → London (overnight)", group = grpP)

grpD = "Behaviour highlighting"
shadeZones = input.bool(true, "Shade ±1σ→±2σ zones",         group = grpD)
colorBars  = input.bool(true, "Tint bars closed beyond ±1σ", group = grpD)
markCross  = input.bool(true, "Mark first close beyond ±1σ", group = grpD)

colTL = input.color(color.blue,   "Tokyo→London colour", group = grpD)
colLN = input.color(color.orange, "London→NY colour",    group = grpD)
colNL = input.color(color.purple, "NY→London colour",    group = grpD)

// ----------------------------- session state ---------------------------------
type Sess
    float openP = na
    float hi    = na
    float lo    = na
    float lastC = na
    array<float> rets
    float mean  = na
    float sd    = na
    bool  closed = false

// time() needs simple-string args, so in-session booleans are computed at the
// top level and passed in.
method step(Sess s, bool inNow) =>
    s.closed := false
    if inNow and not inNow[1]
        s.openP := open
        s.hi    := high
        s.lo    := low
        s.lastC := close
    else if inNow
        s.hi    := math.max(s.hi, high)
        s.lo    := math.min(s.lo, low)
        s.lastC := close
    if inNow[1] and not inNow
        nprior = array.size(s.rets)
        if nprior >= 2
            s.mean := array.avg(s.rets)
            s.sd   := array.stdev(s.rets, false)   // sample std (ddof=1)
        r = math.log(s.lastC / s.openP)
        if not na(r)
            array.push(s.rets, r)
            if array.size(s.rets) > lookback
                array.shift(s.rets)
        s.closed := true

var tokyo  = Sess.new(rets = array.new<float>())
var london = Sess.new(rets = array.new<float>())
var ny     = Sess.new(rets = array.new<float>())

tkIn = not na(time(timeframe.period, tkSess, tkTz))
lnIn = not na(time(timeframe.period, lnSess, lnTz))
nyIn = not na(time(timeframe.period, nySess, nyTz))

tokyo.step(tkIn)
london.step(lnIn)
ny.step(nyIn)

// ------------------------------ bands ----------------------------------------
type Band
    float up1 = na
    float up2 = na
    float dn1 = na
    float dn2 = na
    bool  active  = false
    bool  firstUp = false
    bool  firstDn = false

// Arm bands when the reference closes; disarm after the trigger closes; reset
// the first-cross flags when the trigger session begins.
method update(Band b, Sess refS, Sess trigS, bool trigIn) =>
    if refS.closed and not na(refS.mean) and not na(refS.sd) and array.size(refS.rets) >= minSamples
        b.up1 := refS.openP * math.exp(refS.mean + refS.sd)
        b.up2 := refS.openP * math.exp(refS.mean + 2.0 * refS.sd)
        b.dn1 := refS.openP * math.exp(refS.mean - refS.sd)
        b.dn2 := refS.openP * math.exp(refS.mean - 2.0 * refS.sd)
        b.active := true
    if trigIn and not trigIn[1]
        b.firstUp := false
        b.firstDn := false
    if b.active and trigS.closed
        b.active := false

var bTL = Band.new()
var bLN = Band.new()
var bNL = Band.new()

bTL.update(tokyo,  london, lnIn)
bLN.update(london, ny,     nyIn)
bNL.update(ny,     london, lnIn)

// A band is drawn only WHILE its trigger session is live (that is the window
// where you watch behaviour). Gate each level accordingly.
tlOn = showTL and bTL.active and lnIn
lnOn = showLN and bLN.active and nyIn
nlOn = showNL and bNL.active and lnIn

tl_u1 = tlOn ? bTL.up1 : na
tl_u2 = tlOn ? bTL.up2 : na
tl_d1 = tlOn ? bTL.dn1 : na
tl_d2 = tlOn ? bTL.dn2 : na
ln_u1 = lnOn ? bLN.up1 : na
ln_u2 = lnOn ? bLN.up2 : na
ln_d1 = lnOn ? bLN.dn1 : na
ln_d2 = lnOn ? bLN.dn2 : na
nl_u1 = nlOn ? bNL.up1 : na
nl_u2 = nlOn ? bNL.up2 : na
nl_d1 = nlOn ? bNL.dn1 : na
nl_d2 = nlOn ? bNL.dn2 : na

// ------------------------------ plots ----------------------------------------
BR = plot.style_linebr
p_tl_u1 = plot(tl_u1, "TK→LN +1σ", color.new(colTL, 45), 1, BR)
p_tl_u2 = plot(tl_u2, "TK→LN +2σ", color.new(colTL, 20), 1, BR)
p_tl_d1 = plot(tl_d1, "TK→LN −1σ", color.new(colTL, 45), 1, BR)
p_tl_d2 = plot(tl_d2, "TK→LN −2σ", color.new(colTL, 20), 1, BR)
p_ln_u1 = plot(ln_u1, "LN→NY +1σ", color.new(colLN, 45), 1, BR)
p_ln_u2 = plot(ln_u2, "LN→NY +2σ", color.new(colLN, 20), 1, BR)
p_ln_d1 = plot(ln_d1, "LN→NY −1σ", color.new(colLN, 45), 1, BR)
p_ln_d2 = plot(ln_d2, "LN→NY −2σ", color.new(colLN, 20), 1, BR)
p_nl_u1 = plot(nl_u1, "NY→LN +1σ", color.new(colNL, 45), 1, BR)
p_nl_u2 = plot(nl_u2, "NY→LN +2σ", color.new(colNL, 20), 1, BR)
p_nl_d1 = plot(nl_d1, "NY→LN −1σ", color.new(colNL, 45), 1, BR)
p_nl_d2 = plot(nl_d2, "NY→LN −2σ", color.new(colNL, 20), 1, BR)

zoneUp = shadeZones ? color.new(color.teal, 88) : na
zoneDn = shadeZones ? color.new(color.red,  88) : na
fill(p_tl_u1, p_tl_u2, zoneUp, "TK→LN +σ zone")
fill(p_tl_d1, p_tl_d2, zoneDn, "TK→LN −σ zone")
fill(p_ln_u1, p_ln_u2, zoneUp, "LN→NY +σ zone")
fill(p_ln_d1, p_ln_d2, zoneDn, "LN→NY −σ zone")
fill(p_nl_u1, p_nl_u2, zoneUp, "NY→LN +σ zone")
fill(p_nl_d1, p_nl_d2, zoneDn, "NY→LN −σ zone")

// ------------------------ behaviour highlighting -----------------------------
// Bars tinted while price closes beyond ANY active band (bright beyond ±2σ).
up2Now = (tlOn and close > bTL.up2) or (lnOn and close > bLN.up2) or (nlOn and close > bNL.up2)
up1Now = (tlOn and close > bTL.up1) or (lnOn and close > bLN.up1) or (nlOn and close > bNL.up1)
dn2Now = (tlOn and close < bTL.dn2) or (lnOn and close < bLN.dn2) or (nlOn and close < bNL.dn2)
dn1Now = (tlOn and close < bTL.dn1) or (lnOn and close < bLN.dn1) or (nlOn and close < bNL.dn1)
barCol = up2Now ? color.new(color.teal, 0)  :
         up1Now ? color.new(color.teal, 55) :
         dn2Now ? color.new(color.red, 0)   :
         dn1Now ? color.new(color.red, 55)  : na
barcolor(colorBars ? barCol : na, title = "Beyond-band bars")

// First close beyond ±1σ within each trigger session (the behavioural event).
f_firstUp(Band b, bool on) =>
    sig = on and close > b.up1 and not b.firstUp
    if sig
        b.firstUp := true
    sig
f_firstDn(Band b, bool on) =>
    sig = on and close < b.dn1 and not b.firstDn
    if sig
        b.firstDn := true
    sig

tlXu = f_firstUp(bTL, tlOn), tlXd = f_firstDn(bTL, tlOn)
lnXu = f_firstUp(bLN, lnOn), lnXd = f_firstDn(bLN, lnOn)
nlXu = f_firstUp(bNL, nlOn), nlXd = f_firstDn(bNL, nlOn)

plotshape(markCross and (tlXu or lnXu or nlXu), "▲ broke +1σ",
     shape.triangleup, location.belowbar, color.teal, size = size.tiny)
plotshape(markCross and (tlXd or lnXd or nlXd), "▼ broke −1σ",
     shape.triangledown, location.abovebar, color.red, size = size.tiny)

// Alerts so you can react live.
alertcondition(tlXu or lnXu or nlXu, "Close beyond +1σ", "Price closed beyond a session +1σ band")
alertcondition(tlXd or lnXd or nlXd, "Close beyond −1σ", "Price closed beyond a session −1σ band")
