# Copy to .env and fill in. .env is gitignored — never commit secrets.

# --- Market data (libs/data_manager.py) -------------------------------------
POLYGON_API_KEY=

# --- Telegram forwarder (tools/telegram_forwarder.py) ------------------------
TELEGRAM_API_ID_NAJIB=
TELEGRAM_API_HASH_NAJIB=
TELEGRAM_API_ID_SAMIM_UZ=
TELEGRAM_API_HASH_SAMIM_UZ=
# Chats: numeric IDs (e.g. -1002974483849) or @usernames, comma-separated
SOURCE_CHATS=
SOURCE_CHATS_SAMIM_UZ=
DEST_ACCOUNTS=

# --- Market Preparation web app (server/) -----------------------------------
# SQLAlchemy DSN; MySQL per the system spec. Create the database first:
#   CREATE DATABASE market_prep CHARACTER SET utf8mb4;
MARKET_PREP_DB_URL=mysql+pymysql://root:root@localhost:3306/market_prep

# Session start/finish alerts (Telethon, uses the najib API credentials).
# Set MARKET_PREP_ALERTS=1 to enable; log in once interactively with:
#   python -m server.telegram_alerts
MARKET_PREP_ALERTS=0
TELEGRAM_ALERT_SESSION=alerts_session
TELEGRAM_ALERT_CHAT=
